<form method="post" action="{{ path('app_product_delete', {'id': product.id} | merge(app.request.query.all)) }}" onsubmit="return confirm('Are you sure you want to delete this item?');" style="flex:1">
  <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
  <button class="btn danger" style="width:100%">Delete</button>
</form>
