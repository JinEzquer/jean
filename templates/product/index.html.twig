{% extends 'base.html.twig' %}

{% block title %}Products{% endblock %}

{% block stylesheets %}
  {{ parent() }}
  <style>
    body{background:#f8fafc}

    /* Hide scrollbars but allow scrolling */
    html, body{scrollbar-width: none; -ms-overflow-style: none}
    body::-webkit-scrollbar{width:0;height:0}
    .wrap{max-width:1400px;width:100%;margin:32px auto;padding:0 24px}
    .title{font-family:'Inter',sans-serif;font-weight:800;font-size:42px;margin:0 0 8px;color:#0f172a}
    .subtitle{color:#64748b;font-size:18px;margin:0 0 32px;font-weight:500}
    .actions{display:flex;justify-content:space-between;align-items:center;margin-bottom:40px;gap:20px}
    .page-header{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:40px;gap:20px}
    .btn{display:inline-flex;align-items:center;gap:8px;background:#0f6bdc;color:#fff;border:none;border-radius:12px;padding:12px 24px;font-weight:600;text-decoration:none;transition:all 0.2s ease;font-size:15px}
    .btn:hover{background:#0d5cbf;transform:translateY(-1px);box-shadow:0 4px 12px rgba(15,107,220,0.3)}
    
    /* Enhanced grid layout */
    .grid{display:grid;grid-template-columns:repeat(auto-fill, minmax(320px, 1fr));gap:32px;margin-bottom:40px}
    
    /* Product cards with improved design */
    .p-card{
      background:#fff;
      border:1px solid #e2e8f0;
      border-radius:20px;
      overflow:hidden;
      box-shadow:0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
      transition:all 0.3s ease;
      position:relative;
    }
    
    .p-card:hover{
      transform:translateY(-8px);
      box-shadow:0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 10px 10px -5px rgba(0, 0, 0, 0.04);
      border-color:#cbd5e1;
    }
    
    .p-card .image-container{
      width:100%;
      height:200px;
      background:linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
      position:relative;
      overflow:hidden;
    }
    
    .p-card .image-container img{
      width:100%;
      height:100%;
      object-fit:cover;
      transition:transform 0.3s ease;
    }
    
    .p-card:hover .image-container img{
      transform:scale(1.05);
    }
    
    .p-card .image-placeholder{
      width:100%;
      height:100%;
      display:flex;
      align-items:center;
      justify-content:center;
      background:linear-gradient(135deg, #f1f5f9 0%, #e2e8f0 100%);
      color:#94a3b8;
      font-size:48px;
    }
    
    .p-card .body{
      padding:24px;
    }
    
    .p-card .category-badge{
      display:inline-block;
      background:#f1f5f9;
      color:#475569;
      padding:6px 12px;
      border-radius:8px;
      font-size:12px;
      font-weight:600;
      text-transform:uppercase;
      letter-spacing:0.5px;
      margin-bottom:12px;
    }
    
    .p-card .name{
      font-weight:700;
      font-size:20px;
      margin:0 0 12px;
      color:#0f172a;
      line-height:1.3;
    }
    
    .p-card .desc{
      color:#64748b;
      font-size:14px;
      line-height:1.5;
      margin-bottom:16px;
      display:-webkit-box;
      -webkit-line-clamp:2;
      -webkit-box-orient:vertical;
      overflow:hidden;
    }
    
    .p-card .price-row{
      display:flex;
      justify-content:space-between;
      align-items:center;
      margin-bottom:20px;
      padding-top:16px;
      border-top:1px solid #f1f5f9;
    }
    
    .p-card .price{
      font-weight:800;
      color:#0f6bdc;
      font-size:24px;
      margin:0;
    }
    
    .p-card .expiry{
      font-size:12px;
      color:#ef4444;
      font-weight:500;
      padding:4px 8px;
      background:#fef2f2;
      border-radius:6px;
    }
    
    .p-card .expiry.valid{
      color:#22c55e;
      background:#f0fdf4;
    }
    
    .p-card .row{
      display:flex;
      gap:12px;
    }
    
    .p-card .btn{
      flex:1;
      display:inline-flex;
      align-items:center;
      justify-content:center;
      background:#0f6bdc;
      color:#fff;
      border:none;
      border-radius:10px;
      padding:12px 16px;
      font-weight:600;
      text-decoration:none;
      font-size:14px;
      transition:all 0.2s ease;
    }
    
    .p-card .btn:hover{
      background:#0d5cbf;
      transform:translateY(-1px);
    }
    
    .p-card .btn.secondary{
      background:#f59e0b;
    }
    
    .p-card .btn.secondary:hover{
      background:#d97706;
    }
    
    .p-card .btn.danger{
      background:#ef4444;
    }
    
    .p-card .btn.danger:hover{
      background:#dc2626;
    }
    
    /* Modal overlay for Create Product */
    .modal-overlay{position:fixed;inset:0;background:rgba(0,0,0,.35);display:none;align-items:center;justify-content:center;z-index:1000}
    /* View modal should not dim/alter background */
    #modalView.modal-overlay{background:transparent}
    .modal{width:min(720px,94vw);max-height:90vh;background:#ffffff;border-radius:14px;box-shadow:0 18px 48px rgba(2,8,23,.35);overflow:hidden;border:1px solid #e5e7eb}
    .modal header{display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border-bottom:1px solid #e5e7eb;background:#f8fafc;font-weight:700}
    .modal .body{height:min(70vh, 680px)}
    .modal .body iframe{width:100%;height:100%;border:0;background:transparent}
    .blurred{filter: blur(3px) brightness(.92); transition: filter .15s ease}
    
    /* Empty state */
    .empty-state{
      text-align:center;
      padding:80px 20px;
      color:#64748b;
    }
    
    .empty-state-icon{
      font-size:64px;
      margin-bottom:16px;
      opacity:0.5;
    }
    
    .empty-state h3{
      font-size:24px;
      margin-bottom:8px;
      color:#0f172a;
    }
    
    /* Responsive improvements */
    @media (max-width: 768px){
      .wrap{margin:24px auto;padding:0 16px}
      .title{font-size:32px}
      .subtitle{font-size:16px}
      .grid{grid-template-columns:repeat(auto-fill, minmax(280px, 1fr));gap:24px}
      .actions{flex-direction:column;align-items:stretch}
      .p-card .image-container{height:160px}
      .p-card .body{padding:20px}
      .p-card .name{font-size:18px}
      .p-card .price{font-size:20px}
    }
    
    @media (max-width: 480px){
      .grid{grid-template-columns:1fr;gap:20px}
      .p-card .row{flex-direction:column}
      .p-card .btn{width:100%}
    }
  </style>
{% endblock %}

{% block body %}
  {% set embed = app.request.query.get('embed') == '1' %}
  {% set q = embed ? {'embed': 1} : {} %}
  <div class="wrap" id="contentWrap">
    <div class="page-header">
      <div>
        <h1 class="title">Products</h1>
        <p class="subtitle">Browse our premium selection of quality products</p>
      </div>
      {% if is_granted('ROLE_ADMIN') %}
      <a class="btn" href="#" onclick="openNewProduct(); return false;">+ New Product</a>
      {% endif %}
    </div>

  <!-- Modal: Edit Product -->
  <div class="modal-overlay" id="modalEdit">
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="modalEditTitle">
      <header>
        <div id="modalEditTitle">Edit Product</div>
        <button type="button" onclick="closeEditProduct()" style="background:transparent;border:0;font-weight:900;cursor:pointer">✕</button>
      </header>
      <div class="body">
        <iframe id="iframeEdit" referrerpolicy="no-referrer"></iframe>
      </div>
    </div>
  </div>

  <!-- Modal: View Product -->
  <div class="modal-overlay" id="modalView">
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="modalViewTitle">
      <header>
        <div id="modalViewTitle">Product Details</div>
        <button type="button" onclick="closeViewProduct()" style="background:transparent;border:0;font-weight:900;cursor:pointer">✕</button>
      </header>
      <div class="body">
        <iframe id="iframeView" referrerpolicy="no-referrer"></iframe>
      </div>
    </div>
  </div>

    {# Product cards #}
    {% if products|length > 0 %}
      <div class="grid">
        {% for product in products %}
          <div class="p-card">
            <div class="image-container">
              {% if product.image %}
                <img src="{{ asset('uploads/products/' ~ product.image) }}" alt="{{ product.name }}" loading="lazy" onerror="this.onerror=null; this.src='{{ asset('image/placeholder.jpg') }}';">
              {% else %}
                <div class="image-placeholder">📦</div>
              {% endif %}
            </div>
            <div class="body">
              {% if product.category %}
                <div class="category-badge">{{ product.category.name }}</div>
              {% endif %}
              <h3 class="name">{{ product.name }}</h3>
              {% if product.description is defined and product.description %}
                <p class="desc">{{ product.description }}</p>
              {% endif %}
              <div class="price-row">
                <div class="price">{{ product.price is not null ? ('₱' ~ product.price|number_format(2)) : '—' }}</div>
                {% if product.expiryDate %}
                  {% set today = "now"|date("Y-m-d") %}
                  {% set expiry = product.expiryDate|date("Y-m-d") %}
                  {% set daysUntilExpiry = date(expiry).diff(date(today)).days %}
                  <div class="expiry {% if daysUntilExpiry > 7 %}valid{% endif %}">
                    {% if daysUntilExpiry < 0 %}
                      Expired
                    {% elseif daysUntilExpiry == 0 %}
                      Expires today
                    {% elseif daysUntilExpiry == 1 %}
                      Expires tomorrow
                    {% elseif daysUntilExpiry <= 7 %}
                      {{ daysUntilExpiry }} days left
                    {% else %}
                      Valid until {{ product.expiryDate|date("M j") }}
                    {% endif %}
                  </div>
                {% endif %}
              </div>
              <div class="row">
                <a class="btn" href="#" onclick="openViewProduct({{ product.id }}); return false;">View</a>
                {% if is_granted('ROLE_ADMIN') %}
                  <a class="btn secondary" href="#" onclick="openEditProduct({{ product.id }}); return false;">Edit</a>
                  {{ include('product/_delete_form.html.twig', { product: product }) }}
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    {% else %}
      <div class="empty-state">
        <div class="empty-state-icon">📦</div>
        <h3>No products found</h3>
        <p>Get started by adding your first product to the inventory.</p>
        {% if is_granted('ROLE_ADMIN') %}
          <br><br>
          <a class="btn" href="#" onclick="openNewProduct(); return false;">+ Add Your First Product</a>
        {% endif %}
      </div>
    {% endif %}

    {# Legacy table removed: cards above now provide View/Edit/Delete (CRUD) #}
  </div>

  <!-- Modal: Create Product -->
  <div class="modal-overlay" id="modalNew">
    <div class="modal" role="dialog" aria-modal="true" aria-labelledby="modalNewTitle">
      <header>
        <div id="modalNewTitle">Add Product</div>
        <button type="button" onclick="closeNewProduct()" style="background:transparent;border:0;font-weight:900;cursor:pointer">✕</button>
      </header>
      <div class="body">
        <iframe id="iframeNew" referrerpolicy="no-referrer"></iframe>
      </div>
    </div>
  </div>

  <script>
    (function(){
      const modal = document.getElementById('modalNew');
      const frame = document.getElementById('iframeNew');
      const wrap = document.getElementById('contentWrap');
      const newUrl = '{{ path('app_product_new', q) }}';
      function onFrameLoad(){
        try{
          const loc = frame.contentWindow.location;
          const p = (loc && loc.pathname) ? loc.pathname : '';
          const q = (loc && loc.search) ? loc.search : '';
          // If server hints to close (modal=close), close immediately
          if(q && /[?&]modal=close\b/.test(q)){ closeNewProduct(true); return; }
          // Keep modal open only while on the create form (/product/new)
          const isOnNew = p.endsWith('/product/new');
          if(!isOnNew){ closeNewProduct(true); }
        }catch(_){ /* same-origin, just in case */ }
      }
      window.openNewProduct = function(){
        if(wrap) wrap.classList.add('blurred');
        if(frame){ frame.src = newUrl; }
        if(modal) { modal.style.display = 'flex'; }
        if(frame){ frame.removeEventListener('load', onFrameLoad); frame.addEventListener('load', onFrameLoad); }
      };
      window.closeNewProduct = function(reload){
        if(modal) modal.style.display = 'none';
        if(wrap) wrap.classList.remove('blurred');
        if(frame){ try{ frame.src = 'about:blank'; }catch(_){} }
        if(reload){
          try{ window.scrollTo({top:0, behavior:'instant'}); }catch(_){ try{ window.scrollTo(0,0); }catch(_){} }
          try{ location.reload(); }catch(_){}
        }
      };

      // View Product modal
      const modalView = document.getElementById('modalView');
      const frameView = document.getElementById('iframeView');
      function onViewLoad(){ /* no-op; keep modal open */ }
      window.openViewProduct = function(id){
        /* do not blur background to keep arrangement and background unchanged */
        const viewUrl = '{{ path('app_product_show', {id: 0, embed: 1} | merge(q))|replace({'0':'__ID__'}) }}'.replace('__ID__', id);
        if(frameView){ frameView.src = viewUrl; }
        if(modalView) { modalView.style.display = 'flex'; }
        if(frameView){ frameView.removeEventListener('load', onViewLoad); frameView.addEventListener('load', onViewLoad); }
      };
      window.closeViewProduct = function(){
        if(modalView) modalView.style.display = 'none';
        /* nothing else to revert */
      };

      // Edit Product modal
      const modalEdit = document.getElementById('modalEdit');
      const frameEdit = document.getElementById('iframeEdit');
      function onEditLoad(){
        try{
          const loc = frameEdit.contentWindow.location;
          const href = (loc && loc.href) ? loc.href : '';
          const path = (loc && loc.pathname) ? loc.pathname : '';
          const q = (loc && loc.search) ? loc.search : '';
          // Ignore the initial about:blank load
          if(!path || path === 'about:blank') return;
          const reEdit = /(\/index\.php)?\/product\/[0-9]+\/edit(\?|$)/;
          const reIndex = /(\/index\.php)?\/product\/?(\?|$)/;
          const isOnEdit = reEdit.test(href) || reEdit.test(path);
          const isIndex  = reIndex.test(href) || reIndex.test(path);
          // If server hints to close (modal=close), close immediately
          if(q && /[?&]modal=close\b/.test(q)){ closeEditProduct(true); return; }
          if(!isOnEdit && isIndex){ closeEditProduct(true); }
        }catch(_){ }
      }
      window.openEditProduct = function(id){
        if(frameEdit){ frameEdit.src = '{{ path('app_product_edit', {id: 0} | merge(q))|replace({'0':'__ID__'}) }}'.replace('__ID__', id); }
        if(modalEdit) { modalEdit.style.display = 'flex'; }
        if(frameEdit){ frameEdit.removeEventListener('load', onEditLoad); frameEdit.addEventListener('load', onEditLoad); }
      };
      window.closeEditProduct = function(reload){
        if(modalEdit) modalEdit.style.display = 'none';
        if(frameEdit){ try{ frameEdit.src = 'about:blank'; }catch(_){} }
        if(reload){ try{ location.reload(); }catch(_){} }
      };
    })();
  </script>
{% endblock %}