{% extends 'base.html.twig' %}

{% block title %}Our Services - Patrick's Cold Cuts{% endblock %}

{% block body %}
<!-- Services Section -->
<section class="services-section">
    <div class="container">
        <div class="section-header">
            <h1 class="section-title">Our Services</h1>
            <p class="section-subtitle">Comprehensive frozen food solutions for every need</p>
        </div>
        
        <div class="services-grid">
            <div class="service-card">
                <div class="service-icon">🛒</div>
                <h3>Retail Sales</h3>
                <p>Browse our extensive selection of premium frozen foods, ice creams, and specialty items in our modern retail space.</p>
                <a href="#" class="btn btn-primary">Visit Store</a>
            </div>
            
            <div class="service-card">
                <div class="service-icon">📦</div>
                <h3>Bulk Orders</h3>
                <p>Special pricing and delivery for restaurants, caterers, and large families. Custom orders available.</p>
                <a href="#contact" class="btn btn-primary">Get Quote</a>
            </div>
            
            <div class="service-card">
                <div class="service-icon">🚚</div>
                <h3>Delivery Service</h3>
                <p>Convenient home delivery with temperature-controlled vehicles to maintain product quality.</p>
                <a href="#contact" class="btn btn-primary">Schedule Delivery</a>
            </div>
        </div>
    </div>
</section>

<style>
.services-section {
    padding: 6rem 0;
    background-color: #f8fafc;
}

.services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
}

.service-card {
    background: white;
    border-radius: 0.75rem;
    padding: 2rem;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.service-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
}

.service-icon {
    font-size: 2.5rem;
    margin-bottom: 1.5rem;
}

.service-card h3 {
    font-size: 1.5rem;
    margin-bottom: 1rem;
    color: #0f172a;
}

.service-card p {
    color: #64748b;
    margin-bottom: 1.5rem;
    line-height: 1.6;
}

.btn {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background-color: #0f6bdc;
    color: white;
    text-decoration: none;
    border-radius: 0.5rem;
    font-weight: 500;
    transition: background-color 0.2s;
}

.btn:hover {
    background-color: #0d5cbf;
}

.section-header {
    text-align: center;
    margin-bottom: 3rem;
}

.section-title {
    font-size: 2.25rem;
    color: #0f172a;
    margin-bottom: 1rem;
}

.section-subtitle {
    color: #64748b;
    font-size: 1.125rem;
    max-width: 600px;
    margin: 0 auto;
}
</style>
{% endblock %}
