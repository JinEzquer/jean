{% extends 'base.html.twig' %}

{% block title %}Category · Patrick's Cold Cuts{% endblock %}

{% block body %}
    <style>
      :root{--accent:#005F99;--accent2:#00BFFF;--danger:#D72638;--border:#e5e7eb;--card:#fff;--muted:#64748b}
      body{ background: linear-gradient(180deg, #14384f, #0f2a3f) }
      .navbar{display:none !important}
      .wrap{max-width:720px;margin:40px auto;padding:0 16px}
      .head{display:flex;align-items:center;gap:10px;margin-bottom:12px}
      .title{font-family:'Bebas Neue',sans-serif;font-size:34px;letter-spacing:.03em;color:var(--accent)}
      .card{background:var(--card);border:1px solid var(--border);border-radius:14px;box-shadow:0 6px 16px rgba(0,0,0,.05);overflow:hidden; position:relative; z-index:3}
      .card::before,.card::after{content:none !important}
      .card:hover{transform:none !important; box-shadow:0 2px 6px rgba(2,8,23,.05) !important; background:var(--card) !important; border-color:var(--border) !important}
      .detail-image{ pointer-events:none; max-width:420px !important; width:100%; height:auto; border-radius:12px; box-shadow:0 8px 24px rgba(2,8,23,.08) }
      .table{width:100%;border-collapse:collapse}
      .table th{width:160px;color:#334155;background:#f8fafc}
      .table th,.table td{padding:12px 14px;border-bottom:1px solid var(--border);text-align:left;font-family:'Arimo',sans-serif}
      .actions{display:flex;justify-content:space-between;align-items:center;padding:12px 16px}
      .btn{display:inline-flex;align-items:center;gap:8px;background:#D72638;color:#fff;border:none;border-radius:10px;padding:10px 14px;font-weight:800;text-decoration:none}
      .link{color:var(--accent);text-decoration:none;font-weight:700}
    </style>

    <div class="wrap">
      <div class="head">
        <img src="{{ asset('images/logo.png') }}" alt="Logo" style="width:36px;height:36px;border-radius:8px;object-fit:contain;background:#e6f3ff;padding:4px">
        <div class="title">Category Details</div>
      </div>
      {# Category image #}
      {% set n = category.name|lower %}
      {% if 'white' in n %}
        {% set img = 'image/whitemeat.jpg' %}
      {% elseif 'seafood' in n %}
        {% set img = 'image/seafoods.jpg' %}
      {% elseif 'red' in n %}
        {% set img = 'image/redmeat.jpg' %}
      {% elseif 'processed' in n %}
        {% set img = 'image/processed meats.jpg' %}
      {% else %}
        {% set img = null %}
      {% endif %}
      {% if img %}
        <div style="display:flex;justify-content:center;margin:8px 0 14px; position:relative; z-index:1">
          <img class="detail-image" src="{{ asset(img) }}" alt="{{ category.name }}">
        </div>
      {% endif %}
      <div class="card">
        {% set embed = app.request.query.get('embed') == '1' %}
        {% set q = embed ? {'embed': 1} : {} %}
        <table class="table">
          <tbody>
            <tr>
              <th>ID</th>
              <td>#{{ category.id }}</td>
            </tr>
            <tr>
              <th>Name</th>
              <td>{{ category.name }}</td>
            </tr>
            <tr>
              <th>Description</th>
              <td>{{ category.description ?: '-' }}</td>
            </tr>
          </tbody>
        </table>
        <div class="actions">
          <a class="link" href="{{ path('app_category_index', q) }}">← Back to Categories</a>
          <div style="display:flex;gap:10px;align-items:center">
            <a class="link" href="{{ path('app_category_edit', {'id': category.id} | merge(q)) }}">Edit</a>
            {# Inject embed param into delete form action via query string #}
            <form method="post" action="{{ path('app_category_delete', {'id': category.id} | merge(q)) }}" onsubmit="return confirm('Delete this category?');">
              <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ category.id) }}">
              <button type="submit" class="btn" style="background:#D72638;color:#fff;border-radius:10px;padding:8px 12px;font-weight:800">Delete</button>
            </form>
          </div>
        </div>
      </div>
    </div>
{% endblock %}
