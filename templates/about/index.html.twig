{% extends 'base.html.twig' %}

{% block title %}About Us - Patrick's Cold Cuts{% endblock %}

{% block body %}
<!-- Hero Section -->
<section class="about-hero">
    <div class="container">
        <div class="hero-content">
            <h1 class="hero-title">Our Story</h1>
            <p class="hero-subtitle">Serving premium quality meats to our community for over 20 years</p>
        </div>
    </div>
</section>

<!-- About Content -->
<section class="about-content">
    <div class="container">
        <div class="about-grid">
            <div class="about-text">
                <h2>Welcome to Patrick's Cold Cuts</h2>
                <p class="about-description">
                    Founded in 2003, Patrick's Cold Cuts has been a cornerstone of quality and trust in the meat industry. 
                    What started as a small family business has grown into a premium destination for quality meats, 
                    serving both families and restaurants throughout the region.
                </p>
                <p class="about-description">
                    Our commitment to excellence starts with our carefully selected suppliers and extends to every 
                    aspect of our service. We believe that quality shouldn't be a luxury—it should be the standard.
                </p>
                
                <div class="stats-grid">
                    <div class="stat-item">
                        <div class="stat-number">20+</div>
                        <div class="stat-label">Years of Service</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-number">50K+</div>
                        <div class="stat-label">Happy Customers</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-number">100+</div>
                        <div class="stat-label">Premium Products</div>
                    </div>
                    <div class="stat-item">
                        <div class="stat-number">24/7</div>
                        <div class="stat-label">Fresh Delivery</div>
                    </div>
                </div>
            </div>
            
            <div class="about-image">
            <div style="background: white; border-radius: 50%; padding: 12px; box-shadow: 0 15px 30px rgba(0,0,0,0.25); display: inline-flex; align-items: center; justify-content: center;">
                <img src="{{ asset('image/76468012-d5ef-4a7e-b2d5-d68451667914-removebg-preview.png') }}" alt="About Patrick's Cold Cuts">
            </div>
        </div>
    </div>
</section>

<!-- Values Section -->
<section class="values-section">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">Our Values</h2>
            <p class="section-subtitle">The principles that guide everything we do</p>
        </div>
        
        <div class="values-grid">
            <div class="value-card">
                <div class="value-icon">🏆</div>
                <h3>Quality First</h3>
                <p>We never compromise on quality. Every product meets our strict standards for freshness, taste, and safety.</p>
            </div>
            
            <div class="value-card">
                <div class="value-icon">🤝</div>
                <h3>Customer Trust</h3>
                <p>Building lasting relationships through honesty, transparency, and exceptional service.</p>
            </div>
            
            <div class="value-card">
                <div class="value-icon">🌱</div>
                <h3>Sustainability</h3>
                <p>Committed to responsible sourcing and sustainable practices that protect our environment.</p>
            </div>
            
            <div class="value-card">
                <div class="value-icon">💪</div>
                <h3>Community Focus</h3>
                <p>Supporting local farmers and giving back to the community that has supported us for years.</p>
            </div>
        </div>
    </div>
</section>

<!-- Team Section -->
<section class="team-section">
    <div class="container">
        <div class="section-header">
            <h2 class="section-title">Meet Our Team</h2>
            <p class="section-subtitle">The passionate people behind Patrick's Cold Cuts</p>
        </div>
        
        <div class="team-grid">
            <div class="team-member">
                <div class="member-image">
                    <img src="{{ asset('image/team/patrick.jpg') }}" alt="Patrick">
                </div>
                <h3>Patrick Chen</h3>
                <p class="member-title">Founder & CEO</p>
                <p class="member-bio">With over 25 years in the meat industry, Patrick's expertise and passion drive our commitment to quality.</p>
            </div>
            
            <div class="team-member">
                <div class="member-image">
                    <img src="{{ asset('image/team/sarah.jpg') }}" alt="Sarah">
                </div>
                <h3>Sarah Martinez</h3>
                <p class="member-title">Head of Quality Control</p>
                <p class="member-bio">Sarah ensures every product meets our high standards for freshness and safety.</p>
            </div>
            
            <div class="team-member">
                <div class="member-image">
                    <img src="{{ asset('image/team/mike.jpg') }}" alt="Mike">
                </div>
                <h3>Mike Johnson</h3>
                <p class="member-title">Operations Manager</p>
                <p class="member-bio">Mike oversees our daily operations and ensures smooth delivery services.</p>
            </div>
        </div>
    </div>
</section>

<!-- CTA Section -->
<section class="cta-section">
    <div class="container">
        <div class="cta-content">
            <h2>Experience the Patrick's Difference</h2>
            <p>Join thousands of satisfied customers who trust us for their meat needs</p>
            <div class="cta-buttons">
                <a href="{{ path('app_product_index') }}" class="btn btn-primary">Shop Now</a>
                <a href="#contact" class="btn btn-outline">Contact Us</a>
            </div>
        </div>
    </div>
</section>

<style>
/* Hero Section */
.about-hero {
    background: linear-gradient(135deg, #0A1128 0%, #1a2f4a 100%);
    color: white;
    padding: 120px 0 80px;
    text-align: center;
}

.hero-title {
    font-size: 3.5rem;
    font-weight: 800;
    margin-bottom: 1rem;
}

.hero-subtitle {
    font-size: 1.25rem;
    opacity: 0.9;
    max-width: 600px;
    margin: 0 auto;
}

/* About Content */
.about-content {
    padding: 80px 0;
    background: white;
}

.about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
}

.about-text h2 {
    font-size: 2.5rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 2rem;
}

.about-description {
    font-size: 1.125rem;
    line-height: 1.8;
    color: #64748b;
    margin-bottom: 1.5rem;
}

.stats-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
    margin-top: 3rem;
}

.stat-item {
    text-align: center;
}

.stat-number {
    font-size: 2.5rem;
    font-weight: 800;
    color: #0f6bdc;
    margin-bottom: 0.5rem;
}

.stat-label {
    font-size: 0.875rem;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.about-image {
    display: flex;
    justify-content: center;
    align-items: center;
}

.about-image img {
    width: 100%;
    max-width: 350px;
    height: auto;
    border-radius: 50%;
    box-shadow: 0 15px 30px rgba(0,0,0,0.25);
    transition: all 0.3s ease;
    object-fit: contain;
    background: white;
    padding: 12px;
}

.about-image img:hover {
    transform: scale(1.05);
    box-shadow: 0 25px 50px rgba(37, 99, 235, 0.2);
}

/* Values Section */
.values-section {
    padding: 80px 0;
    background: #f8fafc;
}

.section-header {
    text-align: center;
    margin-bottom: 3rem;
}

.section-title {
    font-size: 2.5rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 1rem;
}

.section-subtitle {
    font-size: 1.125rem;
    color: #64748b;
    max-width: 600px;
    margin: 0 auto;
}

.values-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
}

.value-card {
    background: white;
    padding: 2.5rem 2rem;
    border-radius: 16px;
    text-align: center;
    box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease;
}

.value-card:hover {
    transform: translateY(-5px);
}

.value-icon {
    font-size: 3rem;
    margin-bottom: 1.5rem;
}

.value-card h3 {
    font-size: 1.5rem;
    font-weight: 600;
    margin-bottom: 1rem;
    color: #0f172a;
}

.value-card p {
    color: #64748b;
    line-height: 1.6;
}

/* Team Section */
.team-section {
    padding: 80px 0;
    background: white;
}

.team-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
}

.team-member {
    text-align: center;
    background: #f8fafc;
    padding: 2rem;
    border-radius: 16px;
    transition: transform 0.3s ease;
}

.team-member:hover {
    transform: translateY(-5px);
}

.member-image {
    width: 120px;
    height: 120px;
    border-radius: 50%;
    overflow: hidden;
    margin: 0 auto 1.5rem;
    background: #e2e8f0;
}

.member-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
}

.team-member h3 {
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
    color: #0f172a;
}

.member-title {
    color: #0f6bdc;
    font-weight: 500;
    margin-bottom: 1rem;
}

.member-bio {
    color: #64748b;
    line-height: 1.6;
}

/* CTA Section */
.cta-section {
    padding: 80px 0;
    background: linear-gradient(135deg, #0A1128 0%, #1a2f4a 100%);
    color: white;
    text-align: center;
}

.cta-content h2 {
    font-size: 2.5rem;
    font-weight: 700;
    margin-bottom: 1rem;
}

.cta-content p {
    font-size: 1.125rem;
    opacity: 0.9;
    margin-bottom: 2rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
}

.cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
}

/* Buttons */
.btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s ease;
}

.btn-primary {
    background: #0f6bdc;
    color: white;
}

.btn-primary:hover {
    background: #0d5cbf;
    transform: translateY(-1px);
}

.btn-outline {
    background: transparent;
    color: white;
    border: 2px solid white;
}

.btn-outline:hover {
    background: white;
    color: #0A1128;
}

/* Responsive */
@media (max-width: 768px) {
    .hero-title {
        font-size: 2.5rem;
    }
    
    .about-grid {
        grid-template-columns: 1fr;
        gap: 2rem;
    }
    
    .stats-grid {
        grid-template-columns: repeat(2, 1fr);
        gap: 1rem;
    }
    
    .values-grid,
    .team-grid {
        grid-template-columns: 1fr;
    }
    
    .cta-buttons {
        flex-direction: column;
        align-items: center;
    }
}
</style>
{% endblock %}
