{% extends 'admin/base.html.twig' %}

{% block admin_content %}
  <style>
    /* Cover the entire admin content area with dirty white background */
    .admin-main{background:#f5f5f0 !important}
    .cat-bg{position:relative;margin:0;padding:24px;background:transparent;min-height:100vh;box-sizing:border-box;width:100%}
    .cat-hero{position:relative;margin:0;padding:0;background:transparent}
    .cat-hero .row{max-width:1200px;margin:0 auto}
    .cards{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:20px}
    .c-card{background:rgba(255,255,255,.9);border:1px solid rgba(229,231,235,.8);border-radius:16px;overflow:hidden;box-shadow:0 10px 30px rgba(2,8,23,.12)}
    .c-card img{width:100%;height:180px;object-fit:cover;display:block}
    .c-body{padding:12px 14px}
    .c-name{font-weight:900;margin-bottom:6px}
    .c-desc{color:#6b7280;font-size:14px;min-height:42px}
    .c-actions{display:flex;gap:8px;margin-top:10px}
    .btn{display:inline-flex;align-items:center;justify-content:center;gap:6px;background:#0f6bdc;color:#fff;border:none;border-radius:10px;padding:8px 12px;font-weight:800;text-decoration:none}
    .btn.alt{background:#0b3c6f}
    .table-wrap{max-width:1200px;margin:16px auto}
    table{width:100%;border-collapse:separate;border-spacing:0}
    th{background:#0f6bdc;color:#fff;text-align:left;padding:10px 12px;font-weight:800}
    td{padding:10px 12px;border-top:1px solid rgba(229,231,235,.7);background:transparent;color:#0f172a}
    .table-wrap .card{background:rgba(255,255,255,.88)}
  </style>

  <div class="cat-bg">
    <div class="cat-hero">
      <div class="row" style="display:flex;align-items:center;justify-content:flex-end;margin-bottom:12px">
        <a class="btn" href="{{ path('app_admin_category_new') }}" style="background:#ef4444">+ New Category</a>
      </div>
      <div class="row">
        <div class="cards">
          {% for category in categories %}
            {% set n = category.name is defined and category.name ? category.name|lower : '' %}
            {% set img = null %}
            {% if 'red' in n %}
              {% set img = 'image/steak.jpg' %}
            {% elseif 'white' in n %}
              {% set img = 'image/chicken.jpg' %}
            {% elseif 'seafood' in n or 'fish' in n %}
              {% set img = 'image/fish.jpg' %}
            {% elseif 'processed' in n %}
              {% set img = 'image/sausage.jpg' %}
            {% endif %}
            {% set src = img ? asset(img) : asset('image/logo.png') %}
            <div class="c-card">
              <img src="{{ src }}" alt="{{ category.name }}">
              <div class="c-body">
                <div class="c-name">{{ category.name }}</div>
                <div class="c-desc">{{ category.description|default('') }}</div>
                <div class="c-actions">
                  <a class="btn" href="{{ path('app_admin_category_show', {id: category.id}) }}">View</a>
                  <a class="btn alt" href="{{ path('app_admin_category_edit', {id: category.id}) }}">Edit</a>
                  <form method="post" action="{{ path('app_admin_category_delete', {id: category.id}) }}" onsubmit="return confirm('Are you sure you want to delete this category?');" style="display:inline">
                    <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ category.id) }}">
                    <button type="submit" class="btn" style="background:#dc2626;border:none;cursor:pointer">Delete</button>
                  </form>
                </div>
              </div>
            </div>
          {% else %}
            <div style="color:#eaf2f8">No categories yet.</div>
          {% endfor %}
        </div>
      </div>
    </div>
    {# table removed per request #}
  </div>
{% endblock %}
