{% extends 'admin/base.html.twig' %}

{% block admin_content %}
<div style="padding: 20px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; flex-wrap: wrap; gap: 16px;">
        <h1 style="font-size: 2rem; font-weight: 700; color: #1e293b; margin: 0;">Order Details</h1>
        <div style="display: flex; gap: 12px; flex-wrap: wrap;">
            {% if order.status == 'PENDING_APPROVAL' %}
                <a href="{{ path('admin_order_edit', {id: order.id}) }}" 
                   style="background: #3b82f6; color: white; padding: 10px 20px; border-radius: 8px; text-decoration: none; font-weight: 500;">
                    Edit Order
                </a>
                <form method="post" action="{{ path('admin_order_approve', {id: order.id}) }}" style="display: inline;">
                    <input type="hidden" name="_token" value="{{ csrf_token('approve' ~ order.id) }}">
                    <button type="submit" 
                            style="background: #10b981; color: white; padding: 10px 20px; border: none; border-radius: 8px; font-weight: 500; cursor: pointer;">
                        Approve Order
                    </button>
                </form>
                <form method="post" action="{{ path('admin_order_reject', {id: order.id}) }}" style="display: inline;">
                    <input type="hidden" name="_token" value="{{ csrf_token('reject' ~ order.id) }}">
                    <button type="submit" 
                            style="background: #ef4444; color: white; padding: 10px 20px; border: none; border-radius: 8px; font-weight: 500; cursor: pointer;">
                        Reject Order
                    </button>
                </form>
            {% endif %}
            <a href="{{ path('admin_order_index') }}" 
               style="background: #64748b; color: white; padding: 10px 20px; border-radius: 8px; text-decoration: none; font-weight: 500;">
                Back to Orders
            </a>
        </div>
    </div>

    <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-bottom: 20px;">
        <div style="background: white; border: 1px solid #e2e8f0; border-radius: 12px; padding: 20px;">
            <h2 style="font-size: 1.25rem; font-weight: 600; color: #1e293b; margin: 0 0 16px 0;">Order Information</h2>
            <div style="display: flex; flex-direction: column; gap: 12px;">
                <div>
                    <span style="color: #64748b; font-size: 0.875rem; font-weight: 500;">Order ID:</span>
                    <span style="color: #1e293b; font-weight: 600; margin-left: 8px;">#{{ order.id }}</span>
                </div>
                <div>
                    <span style="color: #64748b; font-size: 0.875rem; font-weight: 500;">Customer:</span>
                    <span style="color: #1e293b; font-weight: 500; margin-left: 8px;">{{ order.customer.getFullName() }}</span>
                </div>
                <div>
                    <span style="color: #64748b; font-size: 0.875rem; font-weight: 500;">Email:</span>
                    <span style="color: #1e293b; margin-left: 8px;">{{ order.customer.email }}</span>
                </div>
                <div>
                    <span style="color: #64748b; font-size: 0.875rem; font-weight: 500;">Order Date:</span>
                    <span style="color: #1e293b; margin-left: 8px;">{{ order.orderDate|date('Y-m-d H:i:s') }}</span>
                </div>
                {% if order.updatedAt %}
                <div>
                    <span style="color: #64748b; font-size: 0.875rem; font-weight: 500;">Last Updated:</span>
                    <span style="color: #1e293b; margin-left: 8px;">{{ order.updatedAt|date('Y-m-d H:i:s') }}</span>
                </div>
                {% endif %}
            </div>
        </div>

        <div style="background: white; border: 1px solid #e2e8f0; border-radius: 12px; padding: 20px;">
            <h2 style="font-size: 1.25rem; font-weight: 600; color: #1e293b; margin: 0 0 16px 0;">Status</h2>
            <div style="margin-bottom: 16px;">
                {% if order.status == 'PENDING_APPROVAL' %}
                    <span style="display: inline-block; padding: 8px 16px; background: #fef3c7; color: #d97706; border-radius: 8px; font-size: 1rem; font-weight: 600;">
                        PENDING APPROVAL
                    </span>
                {% elseif order.status == 'APPROVED' %}
                    <span style="display: inline-block; padding: 8px 16px; background: #dbeafe; color: #2563eb; border-radius: 8px; font-size: 1rem; font-weight: 600;">
                        APPROVED
                    </span>
                {% elseif order.status == 'CANCELED' %}
                    <span style="display: inline-block; padding: 8px 16px; background: #fee2e2; color: #dc2626; border-radius: 8px; font-size: 1rem; font-weight: 600;">
                        CANCELED
                    </span>
                {% endif %}
            </div>
            <div>
                <span style="color: #64748b; font-size: 0.875rem; font-weight: 500;">Total Amount:</span>
                <span style="color: #1e293b; font-weight: 700; font-size: 1.5rem; margin-left: 8px;">₱{{ order.total|number_format(2, '.', ',') }}</span>
            </div>
        </div>
    </div>

    <div style="background: white; border: 1px solid #e2e8f0; border-radius: 12px; padding: 20px;">
        <h2 style="font-size: 1.25rem; font-weight: 600; color: #1e293b; margin: 0 0 20px 0;">Order Items</h2>
        <table style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="background: #f8fafc; border-bottom: 2px solid #e2e8f0;">
                    <th style="padding: 12px 16px; text-align: left; font-weight: 600; color: #475569;">Product</th>
                    <th style="padding: 12px 16px; text-align: left; font-weight: 600; color: #475569;">Price</th>
                    <th style="padding: 12px 16px; text-align: left; font-weight: 600; color: #475569;">Quantity</th>
                    <th style="padding: 12px 16px; text-align: right; font-weight: 600; color: #475569;">Subtotal</th>
                </tr>
            </thead>
            <tbody>
                {% if order.orderItems|length > 0 %}
                    {% for item in order.orderItems %}
                        <tr style="border-bottom: 1px solid #e2e8f0;">
                            <td style="padding: 12px 16px; color: #1e293b; font-weight: 500;">{{ item.product.name }}</td>
                            <td style="padding: 12px 16px; color: #64748b;">₱{{ item.price|number_format(2, '.', ',') }}</td>
                            <td style="padding: 12px 16px; color: #64748b;">{{ item.quantity }}</td>
                            <td style="padding: 12px 16px; color: #1e293b; font-weight: 600; text-align: right;">₱{{ item.subtotal|number_format(2, '.', ',') }}</td>
                        </tr>
                    {% endfor %}
                    <tr style="background: #f8fafc;">
                        <td colspan="3" style="padding: 16px; text-align: right; font-weight: 600; color: #1e293b;">Total:</td>
                        <td style="padding: 16px; text-align: right; font-weight: 700; color: #1e293b; font-size: 1.125rem;">₱{{ order.total|number_format(2, '.', ',') }}</td>
                    </tr>
                {% else %}
                    <tr>
                        <td colspan="4" style="padding: 40px 16px; text-align: center; color: #94a3b8;">
                            No items in this order.
                        </td>
                    </tr>
                {% endif %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}

