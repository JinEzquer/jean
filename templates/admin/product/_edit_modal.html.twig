{{ form_start(productForm, {'attr': {'id': 'prod-edit-form', 'class': 'prod-edit-form'}, 'action': path('app_admin_product_edit', {id: product.id})}) }}
<div class="prod-modal-body">
  <div class="form-group">
    {{ form_label(productForm.name) }}
    {{ form_widget(productForm.name, {'attr': {'placeholder': 'Enter product name'}}) }}
    {{ form_errors(productForm.name) }}
  </div>
  <div class="form-group">
    {{ form_label(productForm.category) }}
    {{ form_widget(productForm.category) }}
    {{ form_errors(productForm.category) }}
  </div>
  <div class="form-group">
    {{ form_label(productForm.price) }}
    {{ form_widget(productForm.price, {'attr': {'placeholder': '0.00', 'step': '0.01'}}) }}
    {{ form_errors(productForm.price) }}
  </div>
  <div class="form-group">
    {{ form_label(productForm.expiryDate) }}
    {{ form_widget(productForm.expiryDate) }}
    {{ form_errors(productForm.expiryDate) }}
  </div>
  <div class="form-group">
    {{ form_label(productForm.imageFile) }}
    {{ form_widget(productForm.imageFile) }}
    {{ form_errors(productForm.imageFile) }}
  </div>
</div>
<div class="prod-modal-footer">
  <button type="button" class="btn-cancel prod-edit-cancel">Cancel</button>
  <button type="submit" class="btn-submit">Update Product</button>
</div>
{{ form_end(productForm) }}
