{% extends 'admin/base.html.twig' %}

{% block admin_content %}
<style>
    .detail-header {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 32px;
    }
    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #64748b;
        text-decoration: none;
        font-weight: 500;
        font-size: 0.875rem;
        transition: color 0.2s;
    }
    .back-link:hover {
        color: #3b82f6;
    }
    .detail-title {
        font-size: 2rem;
        font-weight: 700;
        color: #1e293b;
        margin: 0;
    }
    .detail-card {
        background: white;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 32px;
        max-width: 1200px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
    }
    .product-layout {
        display: flex;
        gap: 32px;
        margin-bottom: 32px;
    }
    .product-image-section {
        flex: 1;
        min-width: 400px;
    }
    .product-image-wrapper {
        width: 100%;
        height: 500px;
        border-radius: 12px;
        overflow: hidden;
        background: #f8fafc;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid #e2e8f0;
    }
    .product-image-wrapper img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
    .no-image {
        width: 100%;
        height: 100%;
        background: linear-gradient(135deg, #f1f5f9, #e2e8f0);
        display: flex;
        align-items: center;
        justify-content: center;
        color: #94a3b8;
        font-size: 1.125rem;
        font-weight: 500;
    }
    .product-info-section {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 24px;
    }
    .product-name {
        font-size: 2.5rem;
        font-weight: 800;
        color: #1e293b;
        margin: 0;
        line-height: 1.2;
    }
    .product-meta {
        display: flex;
        flex-direction: column;
        gap: 16px;
    }
    .meta-item {
        display: flex;
        flex-direction: column;
        gap: 6px;
    }
    .meta-label {
        font-size: 0.875rem;
        font-weight: 600;
        color: #64748b;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .meta-value {
        font-size: 1.125rem;
        font-weight: 600;
        color: #1e293b;
    }
    .meta-value.price {
        font-size: 2rem;
        font-weight: 800;
        color: #059669;
    }
    .category-badge {
        display: inline-flex;
        align-items: center;
        padding: 8px 16px;
        background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
        color: white;
        border-radius: 8px;
        font-size: 0.875rem;
        font-weight: 600;
        width: fit-content;
    }
    .detail-actions {
        display: flex;
        gap: 12px;
        margin-top: auto;
        padding-top: 24px;
        border-top: 2px solid #f1f5f9;
    }
    .btn-edit {
        background: #f1f5f9;
        color: #475569;
        border: 1px solid #e2e8f0;
        padding: 12px;
        border-radius: 8px;
        text-decoration: none;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }
    .btn-edit:hover {
        background: #e2e8f0;
    }
    .btn-delete {
        background: #ef4444;
        color: white;
        padding: 12px;
        border-radius: 8px;
        border: none;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
    }
    .btn-delete:hover {
        background: #dc2626;
    }
    @media (max-width: 968px) {
        .product-layout {
            flex-direction: column;
        }
        .product-image-section {
            min-width: 100%;
        }
        .product-image-wrapper {
            height: 400px;
        }
    }
    .btn-secondary {
        background: #f5f5f0;
        color: #475569;
        border: 2px solid #e2e8f0;
        padding: 12px 24px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        transition: all 0.2s;
    }
    .btn-secondary:hover {
        background: #f0f0eb;
        border-color: #cbd5e1;
        transform: translateY(-1px);
    }
    .btn-primary {
        background: linear-gradient(135deg, #3b82f6 0%, #2563eb 100%);
        color: white;
        border: none;
        padding: 12px 24px;
        border-radius: 10px;
        text-decoration: none;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
        box-shadow: 0 4px 6px -1px rgba(59, 130, 246, 0.3);
        transition: all 0.2s;
    }
    .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 12px -1px rgba(59, 130, 246, 0.4);
    }
</style>

<div style="padding: 24px; width: 100%; box-sizing: border-box;">
    <div class="detail-header">
        <a href="{{ path('app_admin_products') }}" class="back-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M19 12H5M12 19l-7-7 7-7"/>
            </svg>
            Back to Products
        </a>
    </div>
    <h1 class="detail-title">Product Details</h1>

    <div class="detail-card">
        <div class="product-layout">
            <div class="product-image-section">
                <div class="product-image-wrapper">
                    {% if product.image %}
                        <img src="{{ asset(product.image) }}" alt="{{ product.name }}">
                    {% else %}
                        <div class="no-image">No Image Available</div>
                    {% endif %}
                </div>
            </div>
            
            <div class="product-info-section">
                <h2 class="product-name">{{ product.name }}</h2>
                
                <div class="product-meta">
                    <div class="meta-item">
                        <span class="meta-label">Category</span>
                        <div>
                            {% if product.category %}
                                <span class="category-badge">{{ product.category.name }}</span>
                            {% else %}
                                <span class="meta-value" style="color: #94a3b8;">Uncategorized</span>
                            {% endif %}
                        </div>
                    </div>
                    
                    <div class="meta-item">
                        <span class="meta-label">Price</span>
                        <span class="meta-value price">{{ product.price is not null ? ('₱' ~ product.price|number_format(2, '.', ',')) : 'Price N/A' }}</span>
                    </div>
                    
                    <div class="meta-item">
                        <span class="meta-label">Expiry Date</span>
                        <span class="meta-value">{{ product.expiryDate ? product.expiryDate|date('F d, Y') : 'No expiry date set' }}</span>
                    </div>
                </div>

                <div class="detail-actions">
                    <a href="{{ path('app_admin_product_edit', {id: product.id}) }}" class="btn-edit" title="Edit">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                            <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                        </svg>
                    </a>
                    <a href="{{ path('app_admin_products') }}" class="btn-secondary" style="margin-left: auto;">
                        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M19 12H5M12 19l-7-7 7-7"></path>
                        </svg>
                        Back to list
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

