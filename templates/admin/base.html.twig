{% extends 'base.html.twig' %}


{% block stylesheets %}
  {{ parent() }}
  <style>
    /* Reset default margins and padding */
    html, body {
      margin: 0;
      padding: 0;
      height: 100%;
      overflow-y: auto;
      overflow-x: hidden;
    }
    
    /* Hide the main navigation bar and footer in admin section */
    .navbar, footer {
      display: none !important;
    }
    
    /* Adjust the main content to account for removed navbar */
    .admin-main {
      margin-left: 240px !important;
      padding: 0 !important;
      width: calc(100% - 240px) !important;
      min-height: 100vh;
    }
    body {
      margin: 0;
      padding: 0;
    }
    .admin-shell {
      display: flex;
      min-height: 100vh;
      margin: 0;
      padding: 0;
      position: relative;
    }
    .admin-aside {
      width: 240px;
      color: #e5eff7;
      padding: 0 12px 16px 12px;
      display: flex;
      flex-direction: column;
      gap: 0;
      margin: 0;
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      overflow-y: auto;
      scrollbar-width: none; /* Firefox */
      -ms-overflow-style: none; /* IE and Edge */
      background:
        /* subtle moving glow overlay */
        radial-gradient(1200px 600px at -20% -10%, rgba(30,64,90,.20), transparent 60%),
        radial-gradient(800px 400px at 120% 110%, rgba(2,132,199,.07), transparent 60%),
        /* low-poly base */
        url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='480' height='1600' viewBox='0 0 480 1600'><rect width='480' height='1600' fill='%230b1f2d'/><polygon points='0,0 240,0 120,160' fill='%23111f2f' /><polygon points='240,0 480,0 360,160' fill='%23122a3a' /><polygon points='120,160 240,0 360,160 240,320' fill='%23102b3e' /><polygon points='0,320 120,160 240,320 120,480' fill='%230e2333' /><polygon points='240,320 360,160 480,320 360,480' fill='%230e2a3b' /><polygon points='120,480 240,320 360,480 240,640' fill='%23102a3a' /><polygon points='0,640 120,480 240,640 120,800' fill='%230d2130' /><polygon points='240,640 360,480 480,640 360,800' fill='%230f2a3b' /><polygon points='120,800 240,640 360,800 240,960' fill='%23112f43' /><polygon points='0,960 120,800 240,960 120,1120' fill='%230e2333' /><polygon points='240,960 360,800 480,960 360,1120' fill='%23102c40' /></svg>") center/cover no-repeat;
      background-size: 200% 200%, 200% 200%, cover;
      animation: azureFlow 14s ease-in-out infinite;
    }
      background:
        /* subtle moving glow overlay */
        radial-gradient(1200px 600px at -20% -10%, rgba(30,64,90,.20), transparent 60%),
        radial-gradient(800px 400px at 120% 110%, rgba(2,132,199,.07), transparent 60%),
        /* low-poly base */
        url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='480' height='1600' viewBox='0 0 480 1600'><rect width='480' height='1600' fill='%230b1f2d'/><polygon points='0,0 240,0 120,160' fill='%23111f2f' /><polygon points='240,0 480,0 360,160' fill='%23122a3a' /><polygon points='120,160 240,0 360,160 240,320' fill='%23102b3e' /><polygon points='0,320 120,160 240,320 120,480' fill='%230e2333' /><polygon points='240,320 360,160 480,320 360,480' fill='%230e2a3b' /><polygon points='120,480 240,320 360,480 240,640' fill='%23102a3a' /><polygon points='0,640 120,480 240,640 120,800' fill='%230d2130' /><polygon points='240,640 360,480 480,640 360,800' fill='%230f2a3b' /><polygon points='120,800 240,640 360,800 240,960' fill='%23112f43' /><polygon points='0,960 120,800 240,960 120,1120' fill='%230e2333' /><polygon points='240,960 360,800 480,960 360,1120' fill='%23102c40' /></svg>") center/cover no-repeat;
      background-size: 200% 200%, 200% 200%, cover;
      animation: azureFlow 14s ease-in-out infinite;
    }
    @keyframes azureFlow{0%{background-position:0% 50%, 100% 50%, 0% 50%}50%{background-position:100% 50%, 0% 50%, 100% 50%}100%{background-position:0% 50%, 100% 50%, 0% 50%}}
    .admin-brand {
      font-weight: 900;
      color: #fff;
      margin: 0;
      padding: 16px 0;
      font-size: 1.5rem;
      line-height: 1.2;
      position: relative;
      z-index: 1;
    }
    
    .admin-brand .logo {
      display: flex;
      align-items: center;
      gap: 10px;
      text-decoration: none;
      color: inherit;
    }
    
    .admin-brand .logo img {
      width: 40px;
      height: 40px;
      object-fit: contain;
      flex-shrink: 0;
    }
    .profile {
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px;
      border-radius: 12px;
      background: rgba(255,255,255,.05);
      margin-top: 10px;
    }
    .avatar {
      width: 60px;
      height: 60px;
      border-radius: 50%;
      overflow: hidden;
      background: #e6f3ff;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
    }
    .avatar img{width:100%;height:100%;object-fit:cover;display:block}
    .meta{display:flex;flex-direction:column;line-height:1.1}
    .meta .name{font-weight:800;color:#fff}
    .status{display:flex;align-items:center;gap:6px;font-weight:700;color:#86efac}
    .status .dot{width:10px;height:10px;border-radius:50%;background:#22c55e;animation:blink 1.2s steps(1,end) infinite}
    @keyframes blink{0%{opacity:1}50%{opacity:.1}100%{opacity:1}}
    .status.offline{color:#cbd5e1}
    .status.offline .dot{background:#94a3b8;box-shadow:none;animation:none}
    .admin-nav a{display:flex;align-items:center;gap:10px;color:#cbd5e1;text-decoration:none;padding:8px 10px;border-radius:8px;font-size:16px}
    .admin-nav a:hover{background:rgba(255,255,255,.06);color:#fff}
    .admin-nav .icon{width:20px;height:20px;display:inline-flex;align-items:center;justify-content:center}
    .admin-nav .icon svg{width:20px;height:20px;stroke:currentColor;fill:none}
    .admin-sep{height:2px;background:linear-gradient(90deg,#ef4444,#f59e0b,#ef4444);border-radius:2px;opacity:.95;margin:6px 6px 2px;background-size:200% 100%;animation:sepSlide 6s linear infinite}
    @keyframes sepSlide{0%{background-position:0% 50%}100%{background-position:100% 50%}}
    .admin-main{flex:1;background:#f5f5f0;width:calc(100% - 240px);padding:0;margin:0;margin-left:240px;overflow-y:auto;overflow-x:hidden;min-height:100vh}
    .admin-top{display:flex;align-items:center;justify-content:space-between;padding:12px 16px;border-bottom:1px solid #1f3a50;background:#fff}
    .admin-content{padding:18px}
    .btn{display:inline-flex;align-items:center;gap:8px;background:#0f6bdc;color:#fff;border:none;border-radius:10px;padding:8px 12px;font-weight:700;text-decoration:none}
    .btn.plain{background:transparent;color:#cbd5e1;border:1px solid rgba(255,255,255,.2)}
    .btn.plain:hover{background:rgba(255,255,255,.06);color:#fff}
    
    /* Logout button styles */
    .logout-btn {
      margin-top: auto;
      color: #ef4444 !important;
      border-top: 1px solid rgba(255, 255, 255, 0.1);
      margin-top: 20px;
      padding-top: 12px;
    }
    .logout-btn:hover {
      background: rgba(239, 68, 68, 0.1) !important;
    }
    .logout-btn .icon {
      color: #ef4444 !important;
    }
    /* Hide scrollbar for sidebar */
    .admin-aside::-webkit-scrollbar {
      display: none; /* Chrome, Safari, Opera */
    }
    /* Hide scrollbar for main content */
    .admin-main::-webkit-scrollbar {
      display: none; /* Chrome, Safari, Opera */
    }
  </style>
{% endblock %}

{% block body %}
<style>
  /* Ensure admin layout takes full width */
  body { overflow-x: hidden; }
  .admin-shell { 
    display: flex; 
    min-height: 100vh; 
    width: 100%; 
    margin: 0;
    padding: 0;
  }
</style>
  <div class="admin-shell">
    <aside class="admin-aside">
      <div class="admin-brand" aria-hidden="true"></div>
      <div class="profile">
        <a href="{{ path('app_home') }}" class="avatar" aria-label="Go to homepage"><img src="{{ asset('image/logo.png') }}" alt="Logo"></a>
        <div class="meta">
          <a href="{{ path('app_home') }}" style="text-decoration: none;">
            <div class="status" id="adminStatus" style="cursor: pointer;">
              <span class="dot" aria-hidden="true"></span>
              <span id="adminStatusText" style="color: #fff;">Patrick's Cold Cuts</span>
            </div>
          </a>
        </div>
      </div>
      <div class="admin-sep" aria-hidden="true"></div>
      <nav class="admin-nav">
        <a href="{{ path('app_admin') }}">
          <span class="icon" aria-hidden="true" style="color:#1e90ff">
            <svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 13h8V3H3v10zM13 21h8v-8h-8v8zM13 3h8v6h-8V3zM3 21h8v-6H3v6z"/>
            </svg>
          </span>
          <span>Dashboard</span>
        </a>
        <a href="{{ path('app_admin_products') }}">
          <span class="icon" aria-hidden="true" style="color:#ec4899">
            <svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/>
              <path d="M3.3 7L12 12l8.7-5"/>
            </svg>
          </span>
          <span>Products</span>
        </a>
        <a href="{{ path('app_admin_categories') }}">
          <span class="icon" aria-hidden="true" style="color:#0ea5e9">
            <svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M3 6h13"/>
              <path d="M3 12h13"/>
              <path d="M3 18h13"/>
              <path d="M19 6h2"/>
              <path d="M19 12h2"/>
              <path d="M19 18h2"/>
            </svg>
          </span>
          <span>Categories</span>
        </a>
        <a href="{{ path('admin_order_index') }}">
          <span class="icon" aria-hidden="true" style="color:#8b5cf6">
            <svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
              <line x1="3" y1="6" x2="21" y2="6"/>
              <path d="M16 10a4 4 0 0 1-8 0"/>
            </svg>
          </span>
          <span>Orders</span>
        </a>
        {% if is_granted('ROLE_ADMIN') %}
        <a href="{{ path('admin_user_index') }}">
          <span class="icon" aria-hidden="true" style="color:#10b981">
            <svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M16 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
              <path d="M22 21v-2a4 4 0 0 0-3-3.87"/>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"/>
            </svg>
          </span>
          <span>User Management</span>
        </a>
        <a href="{{ path('admin_activity_logs') }}">
          <span class="icon" aria-hidden="true" style="color:#f59e0b">
            <svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
              <line x1="16" y1="13" x2="8" y2="13"/>
              <line x1="16" y1="17" x2="8" y2="17"/>
              <polyline points="10 9 9 9 8 9"/>
            </svg>
          </span>
          <span>Activity Logs</span>
        </a>
        {% endif %}
        <a href="{{ path('app_admin_profile') }}" title="Profile">
          <span class="icon" aria-hidden="true" style="color:#8b5cf6">
            <svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
          </span>
          <span>My Profile</span>
        </a>
      </nav>
      
      <!-- Logout Button -->
      <div class="admin-nav" style="margin-top: auto; padding-top: 16px; border-top: 1px solid rgba(255, 255, 255, 0.1);">
        <a href="{{ path('app_logout') }}" class="logout-btn">
          <span class="icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
              <polyline points="16 17 21 12 16 7"/>
              <line x1="21" y1="12" x2="9" y2="12"/>
            </svg>
          </span>
          <span>Logout</span>
        </a>
      </div>
    </aside>
    <main class="admin-main" style="flex: 1; padding: 0; overflow-y: auto; overflow-x: hidden;">
      <div style="width: 100%; height: 100%;">
        {% block admin_content %}{% endblock %}
      </div>
    </main>
  </div>
{% endblock %}

{% block javascripts %}
  {{ parent() }}
  <script>
    document.addEventListener('DOMContentLoaded', function() {
      // Function to fix layout issues
      function fixLayout() {
        // Force a reflow to ensure all elements are properly sized
        document.body.style.display = 'none';
        document.body.offsetHeight; // Trigger reflow
        document.body.style.display = '';
        
        // Ensure admin content takes full width
        const adminMain = document.querySelector('.admin-main');
        if (adminMain) {
          adminMain.style.flex = '1';
          adminMain.style.width = 'calc(100% - 240px)';
          adminMain.style.marginLeft = '240px';
        }
      }

      // Run once immediately
      fixLayout();
      
      // Run again after a short delay to catch any dynamic content
      setTimeout(fixLayout, 100);
      
      // Run one more time after all resources are loaded
      window.addEventListener('load', fixLayout);
      
      // Fix for WebKit browsers
      if (navigator.userAgent.indexOf('Safari') !== -1 || navigator.userAgent.indexOf('Chrome') !== -1) {
        window.addEventListener('pageshow', function(event) {
          if (event.persisted) {
            fixLayout();
          }
        });
      }
    });
  </script>
{% endblock %}
