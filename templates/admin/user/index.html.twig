{% extends 'admin/base.html.twig' %}

{% block admin_content %}
<div style="padding: 20px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
        <h1 style="font-size: 2rem; font-weight: 700; color: #1e293b;">User Management</h1>
        <a href="{{ path('admin_user_new') }}" style="background: #3b82f6; color: white; padding: 10px 20px; border-radius: 8px; text-decoration: none; font-weight: 500; display: inline-flex; align-items: center; gap: 8px;">
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19"/>
                <line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
            Create New User
        </a>
    </div>

    <div style="background: white; border: 1px solid #e2e8f0; border-radius: 12px; overflow: hidden;">
        <table style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="background: #f8fafc; border-bottom: 2px solid #e2e8f0;">
                    <th style="padding: 12px 16px; text-align: left; font-weight: 600; color: #475569;">ID</th>
                    <th style="padding: 12px 16px; text-align: left; font-weight: 600; color: #475569;">Name</th>
                    <th style="padding: 12px 16px; text-align: left; font-weight: 600; color: #475569;">Email</th>
                    <th style="padding: 12px 16px; text-align: left; font-weight: 600; color: #475569;">Role</th>
                    <th style="padding: 12px 16px; text-align: left; font-weight: 600; color: #475569;">Status</th>
                    <th style="padding: 12px 16px; text-align: left; font-weight: 600; color: #475569;">Date Created</th>
                    <th style="padding: 12px 16px; text-align: left; font-weight: 600; color: #475569;">Actions</th>
                </tr>
            </thead>
            <tbody>
                {% if users|length > 0 %}
                    {% for user in users %}
                        <tr style="border-bottom: 1px solid #e2e8f0;">
                            <td style="padding: 12px 16px; color: #64748b;">{{ user.id }}</td>
                            <td style="padding: 12px 16px; color: #1e293b; font-weight: 500;">{{ user.getFullName() }}</td>
                            <td style="padding: 12px 16px; color: #64748b;">{{ user.email }}</td>
                            <td style="padding: 12px 16px;">
                                {% for role in user.roles %}
                                    {% if role == 'ROLE_ADMIN' %}
                                        <span style="display: inline-block; padding: 4px 8px; background: #fee2e2; color: #dc2626; border-radius: 4px; font-size: 0.875rem; font-weight: 500; margin-right: 4px;">
                                            Admin
                                        </span>
                                    {% elseif role == 'ROLE_STAFF' %}
                                        <span style="display: inline-block; padding: 4px 8px; background: #dbeafe; color: #2563eb; border-radius: 4px; font-size: 0.875rem; font-weight: 500; margin-right: 4px;">
                                            Staff
                                        </span>
                                    {% else %}
                                        <span style="display: inline-block; padding: 4px 8px; background: #f1f5f9; color: #475569; border-radius: 4px; font-size: 0.875rem; font-weight: 500; margin-right: 4px;">
                                            User
                                        </span>
                                    {% endif %}
                                {% endfor %}
                            </td>
                            <td style="padding: 12px 16px;">
                                {% if user.isActive %}
                                    <span style="display: inline-block; padding: 4px 8px; background: #dcfce7; color: #16a34a; border-radius: 4px; font-size: 0.875rem; font-weight: 500;">
                                        Active
                                    </span>
                                {% else %}
                                    <span style="display: inline-block; padding: 4px 8px; background: #fee2e2; color: #dc2626; border-radius: 4px; font-size: 0.875rem; font-weight: 500;">
                                        Inactive
                                    </span>
                                {% endif %}
                            </td>
                            <td style="padding: 12px 16px; color: #64748b; font-size: 0.875rem;">
                                {{ user.createdAt|date('Y-m-d') }}
                            </td>
                            <td style="padding: 12px 16px;">
                                <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                                    <a href="{{ path('admin_user_edit', {id: user.id}) }}" 
                                       style="color: #3b82f6; text-decoration: none; font-size: 0.875rem; font-weight: 500;">
                                        Edit
                                    </a>
                                    <a href="{{ path('admin_user_change_password', {id: user.id}) }}" 
                                       style="color: #8b5cf6; text-decoration: none; font-size: 0.875rem; font-weight: 500;">
                                        Change Password
                                    </a>
                                    {% if user.id != app.user.id %}
                                        <form method="post" action="{{ path('admin_user_toggle_status', {id: user.id}) }}" style="display: inline;">
                                            <input type="hidden" name="_token" value="{{ csrf_token('toggle' ~ user.id) }}">
                                            <button type="submit" 
                                                    style="background: none; border: none; color: #f59e0b; cursor: pointer; font-size: 0.875rem; font-weight: 500; padding: 0;">
                                                {{ user.isActive ? 'Disable' : 'Enable' }}
                                            </button>
                                        </form>
                                        <form method="post" action="{{ path('admin_user_delete', {id: user.id}) }}" 
                                              onsubmit="return confirm('Are you sure you want to delete this user? This action cannot be undone.');" 
                                              style="display: inline;">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                                            <button type="submit" 
                                                    style="background: none; border: none; color: #ef4444; cursor: pointer; font-size: 0.875rem; font-weight: 500; padding: 0;">
                                                Delete
                                            </button>
                                        </form>
                                    {% endif %}
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                {% else %}
                    <tr>
                        <td colspan="7" style="padding: 40px 16px; text-align: center; color: #94a3b8;">
                            No users found.
                        </td>
                    </tr>
                {% endif %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}

