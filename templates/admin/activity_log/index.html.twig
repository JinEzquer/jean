{% extends 'admin/base.html.twig' %}

{% block admin_content %}
<div style="padding: 20px;">
    <h1 style="font-size: 2rem; font-weight: 700; color: #1e293b; margin-bottom: 24px;">Activity Logs</h1>

    <!-- Filters -->
    <div style="background: white; border: 1px solid #e2e8f0; border-radius: 12px; padding: 20px; margin-bottom: 24px;">
        <form method="get" action="{{ path('admin_activity_logs') }}" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 16px; align-items: end;">
            <div>
                <label style="display: block; margin-bottom: 8px; font-weight: 500; color: #475569;">Username/Email</label>
                <input type="text" name="user" value="{{ filters.user }}" placeholder="Search by username..." 
                       style="width: 100%; padding: 8px 12px; border: 1px solid #e2e8f0; border-radius: 6px;">
            </div>
            <div>
                <label style="display: block; margin-bottom: 8px; font-weight: 500; color: #475569;">Action</label>
                <select name="action" style="width: 100%; padding: 8px 12px; border: 1px solid #e2e8f0; border-radius: 6px;">
                    <option value="">All Actions</option>
                    {% for action in action_choices %}
                        <option value="{{ action }}" {% if filters.action == action %}selected{% endif %}>{{ action }}</option>
                    {% endfor %}
                </select>
            </div>
            <div>
                <label style="display: block; margin-bottom: 8px; font-weight: 500; color: #475569;">Date From</label>
                <input type="date" name="date_from" value="{{ filters.date_from }}" 
                       style="width: 100%; padding: 8px 12px; border: 1px solid #e2e8f0; border-radius: 6px;">
            </div>
            <div>
                <label style="display: block; margin-bottom: 8px; font-weight: 500; color: #475569;">Date To</label>
                <input type="date" name="date_to" value="{{ filters.date_to }}" 
                       style="width: 100%; padding: 8px 12px; border: 1px solid #e2e8f0; border-radius: 6px;">
            </div>
            <div>
                <button type="submit" style="background: #3b82f6; color: white; border: none; padding: 8px 16px; border-radius: 6px; font-weight: 500; cursor: pointer;">
                    Filter
                </button>
                <a href="{{ path('admin_activity_logs') }}" style="display: inline-block; margin-left: 8px; padding: 8px 16px; color: #64748b; text-decoration: none; border: 1px solid #e2e8f0; border-radius: 6px;">
                    Clear
                </a>
            </div>
        </form>
    </div>

    <!-- Logs Table -->
    <div style="background: white; border: 1px solid #e2e8f0; border-radius: 12px; overflow: hidden;">
        <table style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="background: #f8fafc; border-bottom: 2px solid #e2e8f0;">
                    <th style="padding: 12px 16px; text-align: left; font-weight: 600; color: #475569;">ID</th>
                    <th style="padding: 12px 16px; text-align: left; font-weight: 600; color: #475569;">Username</th>
                    <th style="padding: 12px 16px; text-align: left; font-weight: 600; color: #475569;">Role</th>
                    <th style="padding: 12px 16px; text-align: left; font-weight: 600; color: #475569;">Action</th>
                    <th style="padding: 12px 16px; text-align: left; font-weight: 600; color: #475569;">Target Data</th>
                    <th style="padding: 12px 16px; text-align: left; font-weight: 600; color: #475569;">Date & Time</th>
                </tr>
            </thead>
            <tbody>
                {% if logs|length > 0 %}
                    {% for log in logs %}
                        <tr style="border-bottom: 1px solid #e2e8f0;">
                            <td style="padding: 12px 16px; color: #64748b;">{{ log.id }}</td>
                            <td style="padding: 12px 16px; color: #1e293b; font-weight: 500;">{{ log.username ?? 'N/A' }}</td>
                            <td style="padding: 12px 16px;">
                                {% if log.userRole %}
                                    <span style="display: inline-block; padding: 4px 8px; background: #e0e7ff; color: #4338ca; border-radius: 4px; font-size: 0.875rem; font-weight: 500;">
                                        {{ log.userRole|replace({'ROLE_': ''}) }}
                                    </span>
                                {% else %}
                                    <span style="color: #94a3b8;">N/A</span>
                                {% endif %}
                            </td>
                            <td style="padding: 12px 16px;">
                                <span style="display: inline-block; padding: 4px 8px; background: #f1f5f9; color: #475569; border-radius: 4px; font-size: 0.875rem; font-weight: 500;">
                                    {{ log.action }}
                                </span>
                            </td>
                            <td style="padding: 12px 16px; color: #64748b; font-size: 0.875rem;">
                                {{ log.getFormattedTargetData() }}
                            </td>
                            <td style="padding: 12px 16px; color: #64748b; font-size: 0.875rem;">
                                {{ log.createdAt|date('Y-m-d H:i:s') }}
                            </td>
                        </tr>
                    {% endfor %}
                {% else %}
                    <tr>
                        <td colspan="6" style="padding: 40px 16px; text-align: center; color: #94a3b8;">
                            No activity logs found.
                        </td>
                    </tr>
                {% endif %}
            </tbody>
        </table>
    </div>

    <!-- Pagination -->
    {% if total_pages > 1 %}
        <div style="margin-top: 24px; display: flex; justify-content: center; gap: 8px;">
            {% if current_page > 1 %}
                <a href="{{ path('admin_activity_logs', {page: current_page - 1}|merge(filters)) }}" 
                   style="padding: 8px 12px; background: white; border: 1px solid #e2e8f0; border-radius: 6px; text-decoration: none; color: #475569;">
                    Previous
                </a>
            {% endif %}
            
            <span style="padding: 8px 12px; color: #64748b;">
                Page {{ current_page }} of {{ total_pages }} ({{ total_logs }} total logs)
            </span>
            
            {% if current_page < total_pages %}
                <a href="{{ path('admin_activity_logs', {page: current_page + 1}|merge(filters)) }}" 
                   style="padding: 8px 12px; background: white; border: 1px solid #e2e8f0; border-radius: 6px; text-decoration: none; color: #475569;">
                    Next
                </a>
            {% endif %}
        </div>
    {% endif %}
</div>
{% endblock %}

