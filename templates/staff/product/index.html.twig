{% extends 'staff/base.html.twig' %}

{% block title %}Products - Patrick's Cold Cuts{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .products-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 40px 20px;
        }
        .page-header {
            margin-bottom: 40px;
            text-align: center;
        }
        .page-title {
            font-size: 3rem;
            font-weight: 800;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 12px;
            letter-spacing: -0.5px;
        }
        .page-subtitle {
            color: #64748b;
            font-size: 1.1rem;
            font-weight: 500;
        }
        .products-wrapper {
            background: white;
            border-radius: 20px;
            padding: 32px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
            position: relative;
            overflow: hidden;
        }
        .products-wrapper::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #667eea, #764ba2);
        }
        .new-product-btn {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 14px 28px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            text-decoration: none;
            border-radius: 12px;
            font-weight: 600;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
            margin-bottom: 30px;
        }
        .new-product-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
        }
        .products-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
            gap: 24px;
        }
        .product-card {
            background: white;
            border: 2px solid #f1f5f9;
            border-radius: 16px;
            overflow: hidden;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.06);
            transition: all 0.3s ease;
            position: relative;
        }
        .product-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 3px;
            background: linear-gradient(90deg, #667eea, #764ba2);
            transform: scaleX(0);
            transition: transform 0.3s ease;
        }
        .product-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.12);
            border-color: #e2e8f0;
        }
        .product-card:hover::before {
            transform: scaleX(1);
        }
        .product-image {
            width: 100%;
            height: 200px;
            object-fit: cover;
            border-radius: 12px 12px 0 0;
            background: linear-gradient(135deg, #f1f5f9, #e2e8f0);
            display: flex;
            align-items: center;
            justify-content: center;
            color: #94a3b8;
            font-size: 0.875rem;
        }
        .product-image img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }
        .product-body {
            padding: 24px;
            display: flex;
            flex-direction: column;
            align-items: center;
            text-align: center;
        }
        .product-name {
            font-weight: 800;
            font-size: 1.25rem;
            color: #1e293b;
            margin-bottom: 12px;
            line-height: 1.3;
        }
        .product-meta {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            margin-bottom: 12px;
            flex-wrap: wrap;
        }
        .creator-badge {
            display: inline-flex;
            align-items: center;
            gap: 6px;
            background: linear-gradient(135deg, #fef3c7, #fde68a);
            color: #92400e;
            border-radius: 20px;
            padding: 6px 14px;
            font-weight: 600;
            font-size: 0.8rem;
        }
        .creator-badge.admin {
            background: linear-gradient(135deg, #dbeafe, #bfdbfe);
            color: #1e40af;
        }
        .cat-tag {
            display: inline-flex !important;
            align-items: center;
            gap: 6px;
            background: transparent;
            color: #0b3c6f;
            border-radius: 0;
            padding: 0;
            font-weight: 800;
            font-size: 11px;
        }
        .price-badge {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            background: #0f6bdc;
            color: white;
            border-radius: 999px;
            padding: 6px 12px;
            font-weight: 900;
            margin: 8px 0;
            min-width: 80px;
        }
        .prod-actions {
            display: flex;
            gap: 10px;
            align-items: center;
            justify-content: center;
            margin-top: 16px;
            flex-wrap: wrap;
        }
        .prod-actions form {
            margin: 0;
        }
        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border: none;
            border-radius: 8px;
            height: 32px;
            padding: 0 12px;
            font-weight: 700;
            text-decoration: none;
            color: white;
            font-size: 12px;
            cursor: pointer;
            transition: all 0.2s ease;
            min-width: 64px;
        }
        .btn.view {
            background: #3a7bd5;
        }
        .btn.view:hover {
            background: #2f6bbf;
        }
        .btn.edit {
            background: #3a7bd5;
        }
        .btn.edit:hover {
            background: #2f6bbf;
        }
        .btn.danger {
            background: #e57373;
        }
        .btn.danger:hover {
            background: #d95c5c;
        }
        .empty-state {
            grid-column: 1 / -1;
            background: white;
            border: 2px dashed #e2e8f0;
            border-radius: 16px;
            padding: 60px 40px;
            text-align: center;
        }
        .empty-state p {
            color: #94a3b8;
            font-size: 1.1rem;
            margin-bottom: 24px;
            font-weight: 500;
        }
        .empty-state .btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 14px 28px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            text-decoration: none;
            border-radius: 12px;
            font-weight: 600;
            box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
        }
        .empty-state .btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
        }
        @media (max-width: 768px) {
            .page-title {
                font-size: 2rem;
            }
            .products-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block staff_content %}
<div class="products-container">
    <div class="page-header">
        <h1 class="page-title">All Products</h1>
        <p class="page-subtitle">View and manage all products, including those created by admins.</p>
    </div>

    <div class="products-wrapper">
        <div style="display: flex; justify-content: center;">
            <a href="{{ path('staff_product_new') }}" class="new-product-btn">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                    <line x1="12" y1="5" x2="12" y2="19"></line>
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                </svg>
                Create New Product
            </a>
        </div>

        <div class="products-grid">
            {% for product in products %}
                <div class="product-card">
                    <div class="product-image">
                        {% if product.image %}
                            <img src="{{ asset(product.image) }}" alt="{{ product.name }}">
                        {% else %}
                            <span>No Image</span>
                        {% endif %}
                    </div>
                    <div class="product-body">
                        <div class="product-name">{{ product.name }}</div>
                        <div class="product-meta">
                            <span class="cat-tag">{{ product.category ? product.category.name : 'Uncategorized' }}</span>
                            {% if product.createdBy %}
                                <span class="creator-badge {{ product.createdBy.isAdmin ? 'admin' : '' }}">
                                    {% if product.createdBy.isAdmin %}
                                        👑 Admin
                                    {% else %}
                                        👤 {{ product.createdBy.firstName }} {{ product.createdBy.lastName }}
                                    {% endif %}
                                </span>
                            {% endif %}
                        </div>
                        <div class="price-badge">{{ product.price is not null ? ('₱' ~ product.price) : 'Price N/A' }}</div>
                        <div class="prod-actions">
                            <a class="btn view" href="{{ path('staff_product_show', {id: product.id}) }}">View</a>
                            <a class="btn edit" href="{{ path('staff_product_edit', {id: product.id}) }}">Edit</a>
                            <form method="post" action="{{ path('staff_product_delete', {id: product.id}) }}" 
                                  onsubmit="return confirm('Are you sure you want to delete this product?');"
                                  class="delete-form">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ product.id) }}">
                                <button class="btn danger" type="submit">Delete</button>
                            </form>
                        </div>
                    </div>
                </div>
            {% else %}
                <div class="empty-state">
                    <p>No products found. Create your first product!</p>
                    <a href="{{ path('staff_product_new') }}" class="btn">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                            <line x1="12" y1="5" x2="12" y2="19"></line>
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                        </svg>
                        Create Product
                    </a>
                </div>
            {% endfor %}
        </div>
    </div>
</div>
{% endblock %}
