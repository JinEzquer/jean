{% extends 'staff/base.html.twig' %}

{% block staff_content %}
<div style="padding: 20px;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px; flex-wrap: wrap; gap: 16px;">
        <h1 style="font-size: 2rem; font-weight: 700; color: #1e293b; margin: 0;">Orders</h1>
        <div style="display: flex; gap: 16px; align-items: center; flex-wrap: wrap;">
            <div style="display: flex; align-items: center; gap: 8px;">
                <label for="sort-select" style="color: #64748b; font-weight: 500; font-size: 0.875rem;">Sort by Date:</label>
                <select id="sort-select" onchange="window.location.href='{{ path('staff_order_index') }}?sort=' + this.value" 
                        style="padding: 8px 12px; border: 1px solid #e2e8f0; border-radius: 6px; background: white; color: #1e293b; font-size: 0.875rem; cursor: pointer;">
                    <option value="DESC" {{ current_sort == 'DESC' ? 'selected' : '' }}>Newest First</option>
                    <option value="ASC" {{ current_sort == 'ASC' ? 'selected' : '' }}>Oldest First</option>
                </select>
            </div>
            <a href="{{ path('staff_order_new') }}" 
               style="background: #8b5cf6; color: white; padding: 10px 20px; border-radius: 8px; text-decoration: none; font-weight: 500; display: inline-flex; align-items: center; gap: 8px; white-space: nowrap;">
                <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="12" y1="5" x2="12" y2="19"/>
                    <line x1="5" y1="12" x2="19" y2="12"/>
                </svg>
                Add New Order
            </a>
        </div>
    </div>

    <div style="background: white; border: 1px solid #e2e8f0; border-radius: 12px; overflow: hidden;">
        <table style="width: 100%; border-collapse: collapse;">
            <thead>
                <tr style="background: #f8fafc; border-bottom: 2px solid #e2e8f0;">
                    <th style="padding: 12px 16px; text-align: left; font-weight: 600; color: #475569;">ORDER ID</th>
                    <th style="padding: 12px 16px; text-align: left; font-weight: 600; color: #475569;">CUSTOMER</th>
                    <th style="padding: 12px 16px; text-align: left; font-weight: 600; color: #475569;">TOTAL</th>
                    <th style="padding: 12px 16px; text-align: left; font-weight: 600; color: #475569;">STATUS</th>
                    <th style="padding: 12px 16px; text-align: left; font-weight: 600; color: #475569;">ORDER DATE</th>
                    <th style="padding: 12px 16px; text-align: left; font-weight: 600; color: #475569;">ACTIONS</th>
                </tr>
            </thead>
            <tbody>
                {% if orders|length > 0 %}
                    {% for order in orders %}
                        <tr style="border-bottom: 1px solid #e2e8f0;">
                            <td style="padding: 12px 16px; color: #1e293b; font-weight: 600;">#{{ order.id }}</td>
                            <td style="padding: 12px 16px; color: #64748b;">{{ order.customer.getFullName() }}</td>
                            <td style="padding: 12px 16px; color: #1e293b; font-weight: 600;">₱{{ order.total|number_format(2, '.', ',') }}</td>
                            <td style="padding: 12px 16px;">
                                {% if order.status == 'PENDING_APPROVAL' %}
                                    <span style="display: inline-block; padding: 6px 12px; background: #fef3c7; color: #d97706; border-radius: 6px; font-size: 0.875rem; font-weight: 600;">
                                        PENDING APPROVAL
                                    </span>
                                {% elseif order.status == 'APPROVED' %}
                                    <span style="display: inline-block; padding: 6px 12px; background: #dbeafe; color: #2563eb; border-radius: 6px; font-size: 0.875rem; font-weight: 600;">
                                        APPROVED
                                    </span>
                                {% elseif order.status == 'CANCELED' %}
                                    <span style="display: inline-block; padding: 6px 12px; background: #fee2e2; color: #dc2626; border-radius: 6px; font-size: 0.875rem; font-weight: 600;">
                                        CANCELED
                                    </span>
                                {% endif %}
                            </td>
                            <td style="padding: 12px 16px; color: #64748b; font-size: 0.875rem;">
                                {{ order.orderDate|date('Y-m-d H:i') }}
                            </td>
                            <td style="padding: 12px 16px;">
                                <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                                    <a href="{{ path('staff_order_show', {id: order.id}) }}" 
                                       style="background: #1e293b; color: white; padding: 6px 12px; border-radius: 6px; text-decoration: none; font-size: 0.875rem; font-weight: 500;">
                                        View
                                    </a>
                                    {% if order.status == 'PENDING_APPROVAL' %}
                                        <a href="{{ path('staff_order_edit', {id: order.id}) }}" 
                                           style="background: #3b82f6; color: white; padding: 6px 12px; border-radius: 6px; text-decoration: none; font-size: 0.875rem; font-weight: 500;">
                                            Edit
                                        </a>
                                        <form method="post" action="{{ path('staff_order_approve', {id: order.id}) }}" style="display: inline;">
                                            <input type="hidden" name="_token" value="{{ csrf_token('approve' ~ order.id) }}">
                                            <button type="submit" 
                                                    style="background: #10b981; color: white; padding: 6px 12px; border: none; border-radius: 6px; font-size: 0.875rem; font-weight: 500; cursor: pointer;">
                                                Approve
                                            </button>
                                        </form>
                                        <form method="post" action="{{ path('staff_order_reject', {id: order.id}) }}" style="display: inline;">
                                            <input type="hidden" name="_token" value="{{ csrf_token('reject' ~ order.id) }}">
                                            <button type="submit" 
                                                    style="background: #ef4444; color: white; padding: 6px 12px; border: none; border-radius: 6px; font-size: 0.875rem; font-weight: 500; cursor: pointer;">
                                                Reject
                                            </button>
                                        </form>
                                    {% endif %}
                                    <form method="post" action="{{ path('staff_order_delete', {id: order.id}) }}" 
                                          onsubmit="return confirm('Are you sure you want to delete this order? This action cannot be undone.');" 
                                          style="display: inline;">
                                        <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ order.id) }}">
                                        <button type="submit" 
                                                style="background: #ef4444; color: white; padding: 6px 12px; border: none; border-radius: 6px; font-size: 0.875rem; font-weight: 500; cursor: pointer;">
                                            Delete
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                {% else %}
                    <tr>
                        <td colspan="6" style="padding: 40px 16px; text-align: center; color: #94a3b8;">
                            No orders found.
                        </td>
                    </tr>
                {% endif %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}

