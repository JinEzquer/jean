{% extends 'staff/base.html.twig' %}

{% block title %}Staff Dashboard - Patrick's Cold Cuts{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <style>
        .dashboard-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 40px 20px;
            font-family: 'Arimo', system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }
        .page-header {
            margin-bottom: 40px;
            text-align: center;
        }
        .page-title {
            font-size: 3rem;
            font-weight: 900;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
            margin-bottom: 12px;
            letter-spacing: -0.5px;
            font-family: 'Arimo', system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }
        .welcome-text {
            color: #64748b;
            font-size: 1.2rem;
            font-weight: 600;
            font-family: 'Arimo', system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }
        .dashboard-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
            gap: 30px;
            margin-bottom: 30px;
        }
        .dashboard-card {
            background: white;
            border-radius: 20px;
            padding: 32px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.08);
            transition: all 0.3s ease;
            border: 1px solid rgba(255, 255, 255, 0.8);
            position: relative;
            overflow: hidden;
        }
        .dashboard-card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 4px;
            background: linear-gradient(90deg, #667eea, #764ba2);
        }
        .dashboard-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 15px 50px rgba(0, 0, 0, 0.12);
        }
        .card-title {
            font-size: 1.5rem;
            font-weight: 800;
            color: #1e293b;
            margin-bottom: 24px;
            padding-bottom: 16px;
            border-bottom: 2px solid #f1f5f9;
            display: flex;
            align-items: center;
            gap: 12px;
            font-family: 'Arimo', system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }
        .card-title::before {
            content: '';
            width: 4px;
            height: 24px;
            background: linear-gradient(135deg, #667eea, #764ba2);
            border-radius: 2px;
        }
        .quick-actions {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }
        .action-btn {
            display: inline-flex;
            align-items: center;
            gap: 12px;
            padding: 16px 20px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            text-decoration: none;
            border-radius: 12px;
            font-weight: 700;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
            position: relative;
            overflow: hidden;
            font-family: 'Arimo', system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }
        .action-btn::before {
            content: '';
            position: absolute;
            top: 0;
            left: -100%;
            width: 100%;
            height: 100%;
            background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.2), transparent);
            transition: left 0.5s;
        }
        .action-btn:hover::before {
            left: 100%;
        }
        .action-btn:hover {
            transform: translateX(5px);
            box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
        }
        .action-btn svg {
            width: 22px;
            height: 22px;
            stroke-width: 2.5;
        }
        .action-btn.secondary {
            background: linear-gradient(135deg, #64748b 0%, #475569 100%);
            box-shadow: 0 4px 15px rgba(100, 116, 139, 0.3);
        }
        .action-btn.secondary:hover {
            box-shadow: 0 6px 20px rgba(100, 116, 139, 0.4);
        }
        .info-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 16px 0;
            border-bottom: 1px solid #f1f5f9;
            transition: background-color 0.2s;
            border-radius: 8px;
            padding-left: 12px;
            padding-right: 12px;
        }
        .info-item:hover {
            background: #f8fafc;
        }
        .info-item:last-child {
            border-bottom: none;
        }
        .info-label {
            color: #64748b;
            font-weight: 800;
            font-size: 0.95rem;
            display: flex;
            align-items: center;
            gap: 8px;
            font-family: 'Arimo', system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }
        .info-label::before {
            content: '';
            width: 6px;
            height: 6px;
            background: #cbd5e1;
            border-radius: 50%;
        }
        .info-value {
            color: #1e293b;
            font-weight: 700;
            font-size: 1rem;
            font-family: 'Arimo', system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }
        .status-badge {
            display: inline-flex;
            align-items: center;
            padding: 6px 12px;
            border-radius: 20px;
            font-size: 0.85rem;
            font-weight: 700;
            font-family: 'Arimo', system-ui, -apple-system, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
        }
        .status-badge.active {
            background: #dcfce7;
            color: #16a34a;
        }
        .status-badge.inactive {
            background: #fee2e2;
            color: #dc2626;
        }
        @media (max-width: 768px) {
            .page-title {
                font-size: 2rem;
            }
            .dashboard-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
{% endblock %}

{% block staff_content %}
<div class="dashboard-container">
    <div class="page-header">
        <h1 class="page-title">Staff Dashboard</h1>
        <p class="welcome-text">Welcome back, {{ app.user.firstName }} {{ app.user.lastName }}! 👋</p>
    </div>

    <div class="dashboard-grid">
        <div class="dashboard-card">
            <h2 class="card-title">Quick Actions</h2>
            <div class="quick-actions">
                <a href="{{ path('staff_product_new') }}" class="action-btn">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <line x1="12" y1="5" x2="12" y2="19"></line>
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                    Create New Product
                </a>
                <a href="{{ path('staff_product_index') }}" class="action-btn secondary">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                        <line x1="9" y1="3" x2="9" y2="21"></line>
                        <line x1="3" y1="9" x2="21" y2="9"></line>
                    </svg>
                    View Products
                </a>
                <a href="{{ path('staff_profile') }}" class="action-btn secondary">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
                        <circle cx="12" cy="7" r="4"></circle>
                    </svg>
                    My Profile
                </a>
            </div>
        </div>

        <div class="dashboard-card">
            <h2 class="card-title">Account Information</h2>
            <div class="info-item">
                <span class="info-label">Email</span>
                <span class="info-value">{{ app.user.email }}</span>
            </div>
            <div class="info-item">
                <span class="info-label">Name</span>
                <span class="info-value">{{ app.user.firstName }} {{ app.user.lastName }}</span>
            </div>
            <div class="info-item">
                <span class="info-label">Role</span>
                <span class="info-value">Staff</span>
            </div>
            <div class="info-item">
                <span class="info-label">Account Status</span>
                <span class="info-value">
                    {% if app.user.isActive %}
                        <span class="status-badge active">✓ Active</span>
                    {% else %}
                        <span class="status-badge inactive">✗ Inactive</span>
                    {% endif %}
                </span>
            </div>
            {% if app.user.lastLogin %}
            <div class="info-item">
                <span class="info-label">Last Login</span>
                <span class="info-value">{{ app.user.lastLogin|date('M d, Y H:i') }}</span>
            </div>
            {% endif %}
        </div>
    </div>
</div>
{% endblock %}
